{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pre-chunk.sh\"",
            "timeout": 15,
            "statusMessage": "Sprint: checking anchor compliance..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/post-chunk.sh\"",
            "timeout": 60,
            "statusMessage": "Sprint: running quality gates..."
          }
        ]
      }
    ]
  }
}
